# Berlin AI Talent Radar — Environment Variables Template
# Copy this file to .env and fill in your real keys
# NEVER commit .env to git

# OpenAI — required for embeddings and RAG (needed in Chat 4)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# RapidAPI — required for JSearch collector (needed in Chat 2)
# Get from: https://rapidapi.com/letscrape-6bRWlWl/api/jsearch
RAPIDAPI_KEY=your_rapidapi_key_here

# Apify — required for LinkedIn collector (needed in Chat 2)
# Get from: https://console.apify.com/account/integrations
APIFY_API_TOKEN=your_apify_token_here

# PostgreSQL — only if using pgvector backend (optional, Chat 4)
# Default backend is numpy — no database needed
DATABASE_URL=postgresql://radar:radar_secret@localhost:5432/berlin_radar